# MongoDB Atlas 연결 문자열 (Atlas 대시보드 → Connect → Drivers 에서 복사)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/catchpoketmon?retryWrites=true&w=majority

# JWT 서명 비밀키 (아무 긴 랜덤 문자열)
JWT_SECRET=please-change-this-to-a-long-random-string

# 프론트엔드 도메인 (CORS 허용). 여러 개면 콤마로 구분
# 예: https://catch-poket-mon.vercel.app,http://localhost:5173
CLIENT_ORIGIN=https://catch-poket-mon.vercel.app,http://localhost:5173

# 포트 (Render 등에서는 자동 주입되므로 보통 설정 불필요)
PORT=3300
